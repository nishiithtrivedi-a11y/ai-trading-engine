# ===========================================================================
# AI Trading Engine - Environment Variables
# ===========================================================================
# Copy this file to .env and fill in credentials as needed.
#   cp .env.example .env
#
# IMPORTANT:
# - Never commit .env to git.
# - Do not store provider secrets in config/data_providers.yaml.
# ===========================================================================

# ---------------------------------------------------------------------------
# Zerodha (Kite Connect)
# ---------------------------------------------------------------------------
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=
ZERODHA_REDIRECT_URL=http://127.0.0.1:8000/api/v1/providers/sessions/zerodha/callback

# ---------------------------------------------------------------------------
# Upstox OAuth
# ---------------------------------------------------------------------------
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_ACCESS_TOKEN=
UPSTOX_REDIRECT_URI=http://127.0.0.1:8000/api/v1/providers/sessions/upstox/callback

# ---------------------------------------------------------------------------
# DhanHQ
# ---------------------------------------------------------------------------
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=

# ---------------------------------------------------------------------------
# Optional analysis provider selection (Phase 4)
# ---------------------------------------------------------------------------
# FUNDAMENTALS_PROVIDER=none
# MACRO_PROVIDER=none
# SENTIMENT_PROVIDER=none
# INTERMARKET_PROVIDER=derived
# ANALYSIS_ALLOW_DERIVED_SENTIMENT_FALLBACK=true
