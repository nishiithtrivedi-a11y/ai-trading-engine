# ===========================================================================
# AI Trading Engine — Environment Variables
# ===========================================================================
# Copy this file to .env and fill in your credentials.
#   cp .env.example .env
#
# NEVER commit .env to git (it is already in .gitignore).
# ===========================================================================

# ---------------------------------------------------------------------------
# Zerodha (Kite Connect) credentials
# Get these from https://developers.kite.trade/
# ---------------------------------------------------------------------------
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=
ZERODHA_REDIRECT_URL=http://127.0.0.1:8000

# ---------------------------------------------------------------------------
# Upstox credentials (optional, for future use)
# ---------------------------------------------------------------------------
# UPSTOX_API_KEY=
# UPSTOX_API_SECRET=
# UPSTOX_ACCESS_TOKEN=
